<?xml version="1.0" encoding="utf-8"?>
<robot name="full_robot">

  <!-- ========= Materials (materials.xacro 대체 최소 정의) ========= -->
  <material name="silver_default">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  <material name="silver_box">
    <color rgba="0.8 0.8 0.85 1.0"/>
  </material>
  <material name="camera">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 1.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 1.0 1.0"/>
  </material>

  <!-- ========= Root base ========= -->
  <link name="base_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <inertia ixx="0.20" iyy="0.26" izz="0.10" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry><box size="0.26 0.16 1.2"/></geometry>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
      <material name="silver_box"/>
    </visual>
    <collision>
      <geometry><box size="0.26 0.16 1.2"/></geometry>
      <origin xyz="0 0 0.6" rpy="0 0 0"/>
    </collision>
  </link>

  <!-- ========= Camera ========= -->
  <link name="camera_link">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 -0.8 0"/>
      <inertia ixx="0.00015" iyy="0.00005" izz="0.00012" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry><box size="0.05 0.18 0.03"/></geometry>
      <origin xyz="0 0 0" rpy="0 -0.8 0"/>
      <material name="camera"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.18 0.03"/></geometry>
      <origin xyz="0 0 0" rpy="0 -0.8 0"/>
    </collision>
  </link>

  <joint name="base_camera" type="fixed">
    <origin rpy="0 0 0" xyz="0.13 0 1.3"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

